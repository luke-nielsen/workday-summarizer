# Required: your OpenAI API key.
OPENAI_API_KEY=sk-...

# Optional: point at an OpenAI-compatible endpoint (e.g. Azure OpenAI, a proxy).
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional overrides (prefixed with WDS_). Defaults shown.
# WDS_MODEL=gpt-4o-2024-08-06
# WDS_FRAME_INTERVAL_SECONDS=30
# WDS_MAX_FRAME_DIMENSION=768
# WDS_IMAGE_DETAIL=auto
# WDS_BATCH_SIZE=12
# WDS_MAX_CONCURRENCY=4
# WDS_REQUEST_TIMEOUT_SECONDS=120
# WDS_MAX_RETRIES=4

# Cost-estimate overrides (USD per million tokens) for non-standard pricing.
# Leave unset to use the built-in price table; unknown models report no cost.
# WDS_INPUT_COST_PER_MTOK=2.5
# WDS_OUTPUT_COST_PER_MTOK=10.0
